{
  "mcpServers": {
    "math-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-math-mcp"],
      "tools": ["*"]
    },
    "quantum-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-quantum-mcp"],
      "tools": ["*"]
    },
    "molecular-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-molecular-mcp"],
      "tools": ["*"]
    },
    "neural-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-neural-mcp"],
      "tools": ["*"]
    },
    "lean-lsp-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["lean-lsp-mcp"],
      "env": {
        "LEAN_PROJECT_PATH": "."
      },
      "tools": ["*"]
    },
    "context7-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "CONTEXT7_API_KEY": ""
      },
      "description": "Real-time library documentation and code examples",
      "tools": ["*"]
    }
  }
}
