{
  "mcpServers": {
    "psianimator-mcp": {
      "type": "stdio",
      "command": "python3",
      "args": ["-m", "psianimator_mcp.cli", "serve"],
      "env": {
        "PSIANIMATOR_CONFIG": "~/.config/psianimator-mcp/config.json"
      },
      "tools": ["*"]
    },
    "arxiv-search-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "arxiv-search-mcp"],
      "tools": ["*"]
    },
    "particlephysics-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "tool",
        "run",
        "--from",
        "git+https://github.com/uzerone/ParticlePhysics-MCP-Server.git",
        "pp-mcp-server"
      ],
      "tools": ["*"]
    },
    "math-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-math-mcp"],
      "tools": ["*"]
    },
    "quantum-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-quantum-mcp"],
      "tools": ["*"]
    },
    "molecular-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-molecular-mcp"],
      "tools": ["*"]
    },
    "neural-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["scicomp-neural-mcp"],
      "tools": ["*"]
    },
    "lean-lsp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["lean-lsp-mcp"],
      "env": {
        "LEAN_PROJECT_PATH": "."
      },
      "tools": ["*"]
    }
  }
}
